{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "djmexxicoexclusives",
  "main": ".open-next/index.js",
  "compatibility_date": "2026-04-06",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "env": {
    "production": {
      "routes": [
        {
          "pattern": "djmexxico.com",
          "zone_name": "djmexxico.com"
        }
      ]
    }
  }
}
