# Test Environment Variables
# Used for Vitest unit/integration tests (in-memory SQLite or test Postgres)
# For E2E tests via Playwright, use these same variables

# === DATABASE ===
# For Vitest unit tests: use in-memory SQLite (set via vitest.config.ts)
# For integration tests: connect to test Postgres instance
DATABASE_URL="postgresql://test:test@localhost:5432/djmexxico_test"

# === CLERK (Test Mode) ===
# Get these from Clerk Dashboard > API Keys > Test Mode
CLERK_SECRET_KEY="sk_test_Your_Clerk_Test_Secret_Key_Here"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_Your_Clerk_Test_Publishable_Key_Here"

# === STRIPE (Test Mode) ===
# Get these from Stripe Dashboard > API Keys
STRIPE_SECRET_KEY="sk_test_Your_Stripe_Test_Secret_Key_Here"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_Your_Stripe_Test_Publishable_Key_Here"

# === APP URLs ===
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# === R2 (Cloudflare) — Test Bucket ===
# Optional: for R2 integration tests
R2_ACCESS_KEY_ID="test_r2_access_key"
R2_SECRET_ACCESS_KEY="test_r2_secret_key"
NEXT_PUBLIC_R2_ACCOUNT_ID="test_r2_account_id"
NEXT_PUBLIC_R2_BUCKET_NAME="djmexxico-test"

# === EMAIL (Resend) — Test Mode ===
# Get from Resend Dashboard
RESEND_API_KEY="re_test_Your_Resend_Test_API_Key_Here"

# === WEBHOOKS (Test) ===
CLERK_WEBHOOK_SECRET="whsec_test_clerk_secret"
STRIPE_WEBHOOK_SECRET="whsec_test_stripe_secret"

# === LOGGING (Optional) ===
NEXT_PUBLIC_LOG_ENDPOINT="http://localhost:3001/api/logs"

# === NODE ENVIRONMENT ===
NODE_ENV="test"

# === TESTING FLAGS ===
# Skip external services in tests (mock them instead)
SKIP_EXTERNAL_CALLS="true"

# Enable verbose logging for test failure diagnosis
TEST_DEBUG="false"

# Webhook timeout for simulations (milliseconds)
WEBHOOK_TIMEOUT_MS="5000"
